# LLM backend: "gemini" for production, "ollama" for local dev
LLM_BACKEND=gemini

# Required for production (gemini backend)
GEMINI_API_KEY=your-gemini-api-key-here

# Local dev only (ollama backend)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Qdrant vector database
# For Qdrant Cloud: set QDRANT_HOST to your cluster URL (without https://)
# and set QDRANT_API_KEY. Leave QDRANT_PORT as 6333 (Qdrant Cloud uses REST on 6333).
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Embeddings & collection
EMBEDDING_MODEL=intfloat/multilingual-e5-large
COLLECTION_NAME=npa

# Data directory (relative to project root or absolute)
DATA_DIR=../НПА

# Telegram bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
